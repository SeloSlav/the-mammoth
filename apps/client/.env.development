# Loaded by Vite in `pnpm dev`. Keep issuer + client id in sync with `apps/auth/.env`.
VITE_SPACETIME_URI=http://127.0.0.1:3000
VITE_SPACETIME_DATABASE=mammoth-local

# Same host as `ISSUER_URL` in apps/auth/.env (JWT `iss` claim).
VITE_AUTH_ISSUER_URL=http://localhost:4001
VITE_OIDC_CLIENT_ID=the-mammoth-client

# Use the same host you open in the browser (localhost vs 127.0.0.1) so PKCE redirect matches.
VITE_OIDC_REDIRECT_URI=http://localhost:5173/auth/callback
