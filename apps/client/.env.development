# Loaded automatically by Vite in `pnpm dev` / `npm run dev` (development mode).
# Override locally with `.env.development.local` (gitignored) if your SpacetimeDB
# listens on another host/port or you use a different publish name.
VITE_SPACETIME_URI=http://127.0.0.1:3000
VITE_SPACETIME_DATABASE=mammoth-local
# Match `ISSUER_URL` in apps/auth/.env (JWT `iss` claim).
VITE_AUTH_ISSUER_URL=http://localhost:4001
VITE_OIDC_CLIENT_ID=the-mammoth-client
