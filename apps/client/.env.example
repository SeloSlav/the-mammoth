# Copy to `apps/client/.env` if you prefer that over the committed
# `.env.development` (same variables; `.env` is gitignored).
#
# SpaceTimeDB HTTP/WebSocket URL (see `spacetime start` output).
VITE_SPACETIME_URI=http://127.0.0.1:3000

# Database name — must match `spacetime publish <name>` (see apps/server/README.md).
VITE_SPACETIME_DATABASE=mammoth-local

# OpenAuth server (`pnpm dev` in apps/auth). Issuer URL must match ISSUER_URL there.
VITE_AUTH_ISSUER_URL=http://localhost:4001

# OIDC client id — must match OIDC_CLIENT_ID on the auth server (default: the-mammoth-client).
VITE_OIDC_CLIENT_ID=the-mammoth-client

# OAuth redirect (defaults to `${origin}/auth/callback` — use that for a second dev client on another port).
# Set explicitly only to pin host (localhost vs 127.0.0.1) to match the tab URL.
# VITE_OIDC_REDIRECT_URI=http://localhost:5173/auth/callback

# SpacetimeDB must be configured to accept JWTs from this issuer (JWKS at
# `${VITE_AUTH_ISSUER_URL}/.well-known/jwks.json`). See SpacetimeDB 2.x auth docs.
