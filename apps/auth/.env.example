# Copy this to .env and fill in your values
NODE_ENV=development
PORT=4001
ISSUER_URL=http://localhost:4001

# For production, set DATABASE_URL to your PostgreSQL connection string
# DATABASE_URL=postgresql://user:pass@host:port/dbname

# Generate JWT keys using: npm run keys
JWT_PRIVATE_KEY=your_private_key_here
JWT_PUBLIC_KEY=your_public_key_here

# Optional production settings
# BCRYPT_ROUNDS=12
# RESEND_API_KEY=your_resend_key_here
# Comma-separated, no spaces (trailing slashes are stripped at runtime).
# Production: if set, ONLY these origins are allowed (defaults are ignored). Include every frontend origin that calls this server (custom domain + Railway URL, etc.).
# CORS_ALLOWED_ORIGINS=https://selo-empire-production.up.railway.app,https://seloempire.com