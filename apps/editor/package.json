{
  "name": "@the-mammoth/editor",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "cross-env EDITOR_SAVE=1 node --import=tsx ./node_modules/vite/bin/vite.js",
    "build": "tsc --noEmit && node --import=tsx ./node_modules/vite/bin/vite.js build",
    "preview": "node --import=tsx ./node_modules/vite/bin/vite.js preview",
    "lint": "eslint .",
    "check-types": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@the-mammoth/engine": "workspace:*",
    "@the-mammoth/game": "workspace:*",
    "@the-mammoth/schemas": "workspace:*",
    "@the-mammoth/world": "workspace:*",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "three": "^0.183.2",
    "zod": "^4.3.6",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.183.1",
    "@vitejs/plugin-react": "^6.0.1",
    "cross-env": "^7.0.3",
    "eslint": "^9.39.4",
    "tsx": "^4.21.0",
    "typescript": "~6.0.2",
    "vite": "^8.0.4",
    "vite-plugin-checker": "^0.12.0",
    "vitest": "^4.1.3"
  }
}
