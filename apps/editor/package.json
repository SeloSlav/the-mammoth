{
  "name": "@the-mammoth/editor",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "sync:apartment-decor-manifest": "node ../client/scripts/sync-apartment-decor-manifest.mjs",
    "sync:apartment-decor-default-scale": "node ../scripts/sync-owned-apartment-decor-default-scale.mjs",
    "dev": "pnpm run sync:apartment-decor-manifest && node ../../scripts/free-local-dev-server-port.mjs --port 5174 --must-include the-mammoth --must-include apps\\editor --must-include vite && cross-env EDITOR_SAVE=1 vite --configLoader runner",
    "build": "pnpm run sync:apartment-decor-manifest && tsc --noEmit && vite build --configLoader runner",
    "preview": "vite preview --configLoader runner",
    "lint": "eslint .",
    "check-types": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/react-fontawesome": "^3.3.1",
    "@the-mammoth/assets": "workspace:*",
    "@the-mammoth/engine": "workspace:*",
    "@the-mammoth/game": "workspace:*",
    "@the-mammoth/net": "workspace:*",
    "@the-mammoth/schemas": "workspace:*",
    "@the-mammoth/spacetime-client": "workspace:*",
    "@the-mammoth/ui-theme": "workspace:*",
    "@the-mammoth/world": "workspace:*",
    "idb-keyval": "^6.2.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sky-cloud-3d": "github:xiaxiangfeng/sky-cloud-3d",
    "spacetimedb": "2.0.1",
    "three": "^0.183.2",
    "zod": "^4.3.6",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/three": "0.183.1",
    "@vitejs/plugin-react": "^6.0.1",
    "cross-env": "^7.0.3",
    "eslint": "^9.39.4",
    "tsx": "^4.21.0",
    "typescript": "~6.0.2",
    "vite": "^8.0.4",
    "vite-plugin-checker": "^0.12.0",
    "vitest": "^4.1.3"
  }
}
